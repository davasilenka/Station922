+  hello.py   — приветствие + все переменные окружения из os.environ
+  env.py     — dump всех переменных (для проверки раздела "Переменные окружения CGI")
+  post_echo.py — читает stdin по CONTENT_LENGTH, отдаёт обратно
+  status.py  — Status: {QUERY_STRING} (для проверки "Обработка Status-заголовка")
+  slow.py    — time.sleep(int(QUERY_STRING or "60"))
+  exit1.py   — sys.exit(1) (для проверки 502)
+  bigoutput.py — "X"*int(QUERY_STRING or "1000000")
+  hello.bat  — BAT-скрипт: echo Content-Type: text/plain, echo., echo Hello...
+
+Создай test_cgi.py — автотесты по критериям приёмки task.md:
+Каждый тест: check(name, condition). Итог: PASS/FAIL. exit(1) если есть FAIL.
+
